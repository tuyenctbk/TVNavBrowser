            <!-- S -->
            <path android:fillColor="#FFFFC857" android:pathData="M101,34h12v3.5h-8.5v2.2h8.5v9.3h-12V45.5h8.5v-2.2h-8.5V34z" />
            <!-- E -->
            <path android:fillColor="#FFFFC857" android:pathData="M122,34v15h12v-3.5h-8.5v-2.2h7.5v-3.5h-7.5V37.5h8.5V34H122z" />
            <!-- R -->
            <path android:fillColor="#FFFFC857" android:pathData="M143,34h7.5c2.5,0 4.5,1.8 4.5,4c0,1.8 -1.2,3.2 -3,3.8l4,7.2h-4l-3.5,-6.5h-2v6.5h-3.5V34z M146.5,39h4c1,0 1.8,-0.7 1.8,-1.8s-0.8,-1.7 -1.8,-1.7h-4V39z" />
