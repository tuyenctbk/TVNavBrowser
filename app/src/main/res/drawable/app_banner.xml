<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Gradient - Professional Deep Navy -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#0B0F19"
                android:startColor="#1E293B"
                android:centerColor="#111827"
                android:type="linear" />
            <size
                android:width="320dp"
                android:height="180dp" />
        </shape>
    </item>

    <!-- Decorative Subtle Grid Pattern -->
    <item>
        <vector
            android:width="320dp"
            android:height="180dp"
            android:viewportWidth="320"
            android:viewportHeight="180">
            <path
                android:fillColor="#08FFFFFF"
                android:pathData="M0,20h320v1h-320z M0,40h320v1h-320z M0,60h320v1h-320z M0,80h320v1h-320z M0,100h320v1h-320z M0,120h320v1h-320z M0,140h320v1h-320z M0,160h320v1h-320z" />
            <path
                android:fillColor="#08FFFFFF"
                android:pathData="M40,0v180h1v-180z M80,0v180h1v-180z M120,0v180h1v-180z M160,0v180h1v-180z M200,0v180h1v-180z M240,0v180h1v-180z M280,0v180h1v-180z" />
        </vector>
    </item>

    <!-- Compass Logo - Enhanced with Shadows and Glow -->
    <item
        android:gravity="center_vertical|left"
        android:left="32dp"
        android:width="84dp"
        android:height="84dp">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">
            <!-- Outer Glow -->
            <path
                android:fillColor="#1AFFFFC8"
                android:pathData="M54,14c-22.09,0 -40,17.91 -40,40s17.91,40 40,40s40,-17.91 40,-40s-17.91,-40 -40,-40z" />

            <!-- Compass Ring -->
            <path
                android:strokeColor="#FFFFC857"
                android:strokeWidth="2.5"
                android:pathData="M54,22c-17.67,0 -32,14.33 -32,32s14.33,32 32,32s32,-14.33 32,-32S71.67,22 54,22z" />

            <!-- Compass Needle - Gold Top -->
            <path
                android:fillColor="#FFFFC857"
                android:pathData="M54,26l12,28l-12,8l-12,-8z" />
            <!-- Compass Needle - Darker Gold Bottom -->
            <path
                android:fillColor="#FFE6A819"
                android:pathData="M54,82l-12,-28l12,-8l12,8z" />

            <!-- Center Pivot with Glow -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M54,51c1.66,0 3,1.34 3,3s-1.34,3 -3,3s-3,-1.34 -3,-3S52.34,51 54,51z" />
        </vector>
    </item>

    <!-- Brand Typography: LITE BROWSER (Stacked Two-Line Lockup) -->
    <item
