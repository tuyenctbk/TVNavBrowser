            <path android:fillColor="#FFFFC857" android:pathData="M10,34h8c2.5,0 4.5,1.5 4.5,3.5c0,1.8 -1.2,2.8 -3,3.2c2,0.4 3.5,1.5 3.5,3.8c0,2.5 -2,4.5 -5,4.5h-8V34z M13.5,39h4.5c1,0 1.8,-0.7 1.8,-1.7s-0.8,-1.8 -1.8,-1.8h-4.5V39z M13.5,45.5h5c1,0 2,-0.7 2,-1.7s-1,-1.8 -2,-1.8h-5V45.5z" />
            <!-- R -->
