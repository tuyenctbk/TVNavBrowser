        android:left="132dp"
        android:width="156dp"
        android:height="48dp">
        <vector
            android:width="200dp"
            android:height="62dp"
            android:viewportWidth="200"
            android:viewportHeight="62">
            <!-- Line 1: LITE (White) -->
            <!-- L -->
            <path android:fillColor="#FFFFFF" android:pathData="M10,5v20h18v-4h-14V5h-4z" />
            <!-- I -->
            <path android:fillColor="#FFFFFF" android:pathData="M34,5v20h4V5h-4z" />
            <!-- T -->
            <path android:fillColor="#FFFFFF" android:pathData="M44,5h20v4h-8v16h-4V9h-8V5z" />
