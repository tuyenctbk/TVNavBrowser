<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_toolbar"
    android:padding="8dp">

    <ImageView
        android:id="@+id/ivTipIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:srcCompat="@drawable/ic_nav_settings"
        android:contentDescription="Tip"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:tint="@color/accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NaviTV Tips"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvAdTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plug in a USB or Bluetooth mouse for easy web navigation!"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_step_badge"
        android:paddingStart="6dp"
        android:paddingTop="2dp"
        android:paddingEnd="6dp"
        android:paddingBottom="2dp"
        android:text="GUIDE"
        android:textColor="@color/accent"
        android:textSize="9sp"
        android:textStyle="bold" />
</LinearLayout>
